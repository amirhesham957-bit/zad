{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "zad (Web Port 8080)",
      "request": "launch",
      "type": "dart",
      "args": [
        "--web-port",
        "8080",
        "--web-renderer",
        "canvaskit"
      ]
    },
    {
      "name": "zad (Web Server Mode)",
      "request": "launch",
      "type": "dart",
      "args": [
        "-d",
        "web-server",
        "--web-port",
        "8080"
      ]
    }
  ]
}
